-# UC2 — Vue brouillon : personnalisation du menu (card grid)
-# Design : mockup easymeal_menu_customize.html — Slate Craft Premium
-# menu : Menu(status: :draft)
-# menu_recipes : collection ordonnée des MenuRecipe

.mc-page-outer
  .mc-page-wrap

    .mc-page-header
      .mc-page-title Personnalise ton menu
      .mc-page-hint Glisse pour réordonner

    .mc-card-grid{ data: { menu_customize_target: "grid" } }

      - if menu_recipes.any?
        - menu_recipes.each do |mr|
          = render "menu_recipe_card", menu_recipe: mr, menu: menu
      - else
        .mc-empty-grid
          %p.mc-empty-text Aucun repas dans ce menu.

      -# ── Slot d'ajout (2 boutons empilés) ─────────────────
      .mc-add-slot{ id: "add_slot", data: { menu_customize_target: "addSlot" } }
        = link_to recipes_path, class: "mc-add-btn" do
          = svg_icon("search", size: 15)
          %span Depuis le catalogue
        = button_to add_random_meal_menu_path(menu), method: :post, class: "mc-add-btn" do
          = svg_icon("shuffle", size: 15)
          %span Repas aléatoire

    -# ── Bouton de validation ───────────────────────────────
    .mc-validate-zone
      = button_to activate_menu_path(menu), method: :post, class: "mc-btn-validate",
                  disabled: menu_recipes.empty?,
                  form: { data: { turbo_confirm: "Valider le menu ? La liste de courses sera générée." } } do
        Valider et générer la liste de courses
        = svg_icon("arrow-right", size: 15)
