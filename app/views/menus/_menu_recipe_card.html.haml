-# Carte compacte d'un repas (UC2 — card grid)
-# Photo carrée + nom + barre d'actions (remplacer / personnes / supprimer)
-# menu_recipe : MenuRecipe
-# menu : Menu

= turbo_frame_tag "menu_recipe_#{menu_recipe.id}" do
  .mc-recipe-card{ draggable: "true",
                   data: { menu_customize_target: "card",
                           action: "dragstart->menu-customize#dragStart dragend->menu-customize#dragEnd dragover->menu-customize#dragOver dragleave->menu-customize#dragLeave drop->menu-customize#drop" } }

    -# ── Photo carrée ──────────────────────────────────────
    .mc-card-photo
      - if menu_recipe.recipe.photo.attached?
        = image_tag menu_recipe.recipe.photo.variant(resize_to_fill: [260, 260]),
                    alt: menu_recipe.recipe.name
      - else
        = image_tag "photo_par_defaut_recette.png", alt: menu_recipe.recipe.name, class: "mc-card-photo-default"
      .mc-drag-hint
        = svg_icon("grip-vertical", size: 10)

    -# ── Nom de la recette ─────────────────────────────────
    .mc-card-name-wrap
      .mc-card-name= menu_recipe.recipe.name

    -# ── Barre d'actions : remplacer | personnes | supprimer
    .mc-card-actions
      = form_with url: replace_meal_menu_path(menu), method: :post, class: "mc-act-form" do |f|
        = f.hidden_field :menu_recipe_id, value: menu_recipe.id
        %button.mc-act-btn{ type: "submit", title: "Remplacer aléatoirement" }
          = svg_icon("shuffle", size: 12)

      = form_with model: [menu, menu_recipe], method: :patch, class: "mc-act-form",
                  data: { controller: "auto-submit" } do |f|
        = f.select :number_of_people,
                   people_select_options,
                   { selected: menu_recipe.number_of_people },
                   class: "mc-ppl-select", title: "Nombre de personnes",
                   data: { action: "change->auto-submit#submit" }

      = form_with url: menu_menu_recipe_path(menu, menu_recipe), method: :delete,
                  class: "mc-act-form",
                  data: { turbo_confirm: "Retirer ce repas du menu ?" } do
        %button.mc-act-btn.mc-del{ type: "submit", title: "Retirer du menu" }
          = svg_icon("trash", size: 12)
