-# Formulaire de génération d'un menu (UC1)
-# Paramètres : régime, nombre de personnes, nombre de repas, nom optionnel

= form_with model: menu, url: menus_path, method: :post, class: "mn-form" do |f|

  -# ── Section principale ──────────────────────────────────
  .mn-form-section
    .mn-section-label PARAMÈTRES DE GÉNÉRATION

    .form-row
      -# Régime alimentaire
      .form-group{ class: field_error_class(menu, :diet) }
        = f.label :diet, "Régime alimentaire *", class: "form-label"
        = f.select :diet,
                   Menu.diets.keys.map { |d| [menu_diet_label(d), d] },
                   { selected: menu.diet || current_user.default_diet },
                   class: "form-select"
        = field_errors(menu, :diet)

      -# Nombre de personnes
      .form-group{ class: field_error_class(menu, :default_people) }
        = f.label :default_people, "Personnes *", class: "form-label"
        = f.number_field :default_people,
                         value: menu.default_people || current_user.default_people,
                         min: 1, max: 20,
                         class: "form-input"
        = field_errors(menu, :default_people)

    .form-row
      -# Nombre de repas
      .form-group
        = f.label :number_of_meals, "Nombre de repas *", class: "form-label"
        = f.select :number_of_meals,
                   (3..7).map { |n| ["#{n} repas", n] },
                   { selected: 5 },
                   class: "form-select"

      -# Nom du menu (optionnel)
      .form-group
        = f.label :name, "Nom du menu (optionnel)", class: "form-label"
        = f.text_field :name,
                       value: menu.name,
                       placeholder: "Ex: Semaine du 31 mars",
                       class: "form-input"

  -# ── Actions ──────────────────────────────────────────────
  .mn-form-actions
    = f.submit "Générer mon menu →", class: "btn btn-primary btn-lg"
    = link_to "Annuler", menus_path, class: "btn btn-link"
