-# UC3 — Vue menu actif : liste de courses groupée par rayon
-# menu : Menu(status: :active)
-# grocery_items : collection triée GroceryItem

.menu-active

  -# ── En-tête liste de courses ─────────────────────────────
  .grocery-header
    %h2.grocery-title Liste de courses
    .grocery-header-actions
      = button_to "↻ Régénérer", regenerate_grocery_menu_path(menu),
                  method: :post,
                  class: "btn btn-secondary btn-sm",
                  form: { data: { turbo_confirm: "Régénérer la liste ? Les items manuels et cochés seront conservés." } }

  -# ── Liste groupée par rayon ──────────────────────────────
  #grocery_list
    - if grocery_items.any?
      - grocery_items.group_by(&:category).each do |category, items|
        .grocery-section
          %h3.grocery-category-title= category.presence || "Divers"
          .grocery-items-list
            - items.each do |item|
              = render "grocery_item", item: item, menu: menu
    - else
      .grocery-empty
        %p La liste de courses est vide.

  -# ── Ajout manuel ─────────────────────────────────────────
  .grocery-add-manual
    .grocery-add-manual-label AJOUTER UN ARTICLE

    = form_with url: menu_grocery_items_path(menu), method: :post, class: "grocery-add-form" do |f|
      .grocery-add-row
        .form-group
          = f.label :name, "Article", class: "form-label"
          = f.text_field :name, placeholder: "Ex: Sel fin", class: "form-input", required: true

        .form-group
          = f.label :quantity_base, "Quantité", class: "form-label"
          = f.number_field :quantity_base, placeholder: "250", min: 0, step: 0.01, class: "form-input"

        .form-group
          = f.label :base_unit, "Unité", class: "form-label"
          = f.select :base_unit,
                     [["g", "g"], ["ml", "ml"], ["pièce(s)", "piece"], ["càc", "cac"]],
                     { prompt: "Choisir…" },
                     class: "form-select"

        .form-group
          = f.label :unit_group, "Type", class: "form-label"
          = f.select :unit_group,
                     GroceryItem.unit_groups.keys.map { |k| [k.humanize, k] },
                     { prompt: "Choisir…" },
                     class: "form-select"

        .form-group
          = f.label :category, "Rayon", class: "form-label"
          = f.text_field :category, placeholder: "Épicerie, Boucherie…", class: "form-input"

        .grocery-add-submit
          = f.submit "Ajouter", class: "btn btn-primary btn-sm"
