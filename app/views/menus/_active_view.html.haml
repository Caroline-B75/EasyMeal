-# UC3 — Vue menu actif : grille de recettes en lecture seule (même layout que le brouillon)
-# Bouton d'accès à la liste de courses au lieu de "Valider et générer"
-# menu : Menu(status: :active)
-# menu_recipes : collection ordonnée des MenuRecipe

.mc-page-outer
  .mc-page-wrap

    .mc-page-header
      .mc-page-title Mon menu
      .mc-page-hint= "#{menu_recipes.size} repas"

    .mc-card-grid
      - if menu_recipes.any?
        - menu_recipes.each do |mr|
          = render "menu_recipe_card_readonly", menu_recipe: mr
      - else
        .mc-empty-grid
          %p.mc-empty-text Aucun repas dans ce menu.

    -# ── Bouton d'accès à la liste de courses ─────────────
    .mc-validate-zone
      = link_to grocery_menu_path(menu), class: "mc-btn-validate" do
        Voir la liste de courses
        = svg_icon("list", size: 15)
