-# UC1 — Génération d'un nouveau menu (design mockup card-based)
- content_for :title, "Générer un nouveau menu"

.mn-back-bar
  = link_to menus_path, class: "mn-back-link" do
    = svg_icon("chevron-left", size: 14, css_class: "mn-back-chevron")
    Retour à mes menus

.mn-page-wrap
  .mn-page-header
    .mn-page-kicker
      %span.mn-page-kicker-sep
      Planification
    %h1.mn-page-title Générer un nouveau menu
    %p.mn-page-sub Quelques paramètres suffisent — EasyMeal sélectionne des recettes adaptées et de saison.

  = render "form_generate", menu: @menu
