-# UC1/UC2 — Édition des paramètres du menu
-# Brouillon : formulaire complet (régime, personnes, repas, nom) → re-génération
-# Actif/Archivé : formulaire simple (nom, personnes)
- content_for :title, "Modifier le menu"

.mn-back-bar
  = link_to menu_path(@menu), class: "mn-back-link" do
    = svg_icon("chevron-left", size: 14, css_class: "mn-back-chevron")
    Retour au menu

- if @menu.status_draft?
  .mn-page-wrap
    .mn-page-header
      .mn-page-kicker
        %span.mn-page-kicker-sep
        Modifier les paramètres
      %h1.mn-page-title Régénérer le menu
      %p.mn-page-sub Modifie les paramètres ci-dessous. Le menu sera re-généré avec de nouvelles recettes.

    = render "form_regenerate", menu: @menu

- else
  .mn-hero
    .mn-hero-inner
      .mn-kicker
        %span.mn-kicker-line
        MODIFIER LE MENU
      %h1.mn-hero-title= @menu.name.presence || "Menu sans nom"

  .mn-body
    = render "form_edit", menu: @menu
