-# Page d'accueil EasyMeal — contextuelle selon l'état de l'utilisateur
%section.hero-section
  -# Image de fond avec overlay gradient
  .hero-background
    = image_tag "backgrounds/kitchen_2.jpg", alt: "Cuisine moderne EasyMeal"

  -# Contenu principal
  .hero-content
    -# Logo EasyMeal
    .hero-logo
      = image_tag "logos/logo_EasyMeal.svg", alt: "EasyMeal - Planification de repas simplifiée"

    - if user_signed_in?
      - greeting = random_greeting(current_user)
      .hero-greeting
        %p.hero-greeting-text= greeting.text
        %p.hero-greeting-subtext= greeting.subtext
      = render "home/dashboard"
    - else
      = render "home/vitrine"
