-# Partial dashboard — utilisateur connecté
-# Affiche les actions contextuelles : brouillon, menu actif, ou création

- if @draft
  = render "home/dashboard_draft", draft: @draft

- elsif @active_menu
  = render "home/dashboard_active", active_menu: @active_menu

- else
  -# === Aucun menu : accueil par défaut ===
  .hero-dashboard-actions
    = link_to "Créer un nouveau menu", new_menu_path, class: "btn-hero"
    = link_to "Voir les recettes", recipes_path, class: "btn-hero btn-hero--secondary"
