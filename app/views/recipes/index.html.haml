-# UC5 : Catalogue & Recherche de recettes avec filtres
- content_for :title, "Recettes"

.recipes-container{ data: { controller: "recipe-filter" } }

  -# ── Variables filtres (calculées avant le layout pour le badge mobile) ──
  - selected_tag_ids = Array(params[:tag_ids]).map(&:to_s)
  - tags_count = selected_tag_ids.size
  - has_query    = params[:query].present?
  - has_diet     = params[:diet].present?
  - has_diff     = params[:difficulty].present?
  - has_time     = params[:max_time].present?
  - has_seasonal = params[:seasonal] == "true"
  - has_favs     = params[:favorites] == "true"
  - has_any_filter = has_query || has_diet || has_diff || has_time || has_seasonal || has_favs || tags_count > 0
  - active_count = [has_query, has_diet, has_diff, has_time, has_seasonal, has_favs].count(true) + tags_count

  -# ── Bouton flottant mobile (pill fixe en bas, invisible sur desktop) ──
  %button.filters-mobile-btn{ type: "button",
                              "aria-label": "Ouvrir les filtres",
                              data: { action: "click->recipe-filter#openSidebar",
                                      recipe_filter_target: "mobileTrigger" } }
    Filtres
    - if active_count > 0
      %span.filters-mobile-badge= active_count

  -# ── Overlay backdrop (ferme la sidebar au tap en dehors) ──
  .filters-backdrop{ data: { action: "click->recipe-filter#closeSidebar",
                             recipe_filter_target: "backdrop" } }

  -# ── Layout principal : colonne filtres + colonne résultats ──
  .recipes-body

    -# ── Sidebar gauche : tous les filtres ──────────────────
    .recipes-sidebar{ data: { recipe_filter_target: "sidebar" } }
      .sidebar-header
        %h2.sidebar-title Filtres
        = link_to "Effacer", recipes_path, class: "reset-filters-btn"
        %button.sidebar-close-btn{ type: "button",
                                   "aria-label": "Fermer les filtres",
                                   data: { action: "click->recipe-filter#closeSidebar" } } ✕

      = form_with url: recipes_path, method: :get,
                  class: "filters-form",
                  data: { turbo_frame: "recipes_list", recipe_filter_target: "form" } do |f|

        -# ── Barre de recherche (icône intégrée dans le champ) ──
        .filters-search-row
          .search-field-wrapper
            = f.search_field :query,
                             value: params[:query],
                             placeholder: "Rechercher...",
                             class: "search-input"
            = f.submit "🔍", class: "search-inline-btn", title: "Rechercher"

        -# ── Filtres empilés verticalement ──
        .filters-quick-column
          -# Favoris en premier, sous forme de case à cocher
          - if user_signed_in?
            - fav_active = params[:favorites] == "true"
            .filter-group.filter-checkbox{ class: fav_active ? "filter-checkbox--active" : nil }
              = check_box_tag :favorites, "true", fav_active,
                              id: "filter-favorites",
                              data: { action: "change->recipe-filter#submit" }
              = label_tag "filter-favorites", "♥ Mes favoris", class: "filter-label-inline"

          .filter-group
            = f.label :diet, "Régime", class: "filter-label"
            = f.select :diet,
                       options_for_select(Recipe.diets.keys.map { |d| [d.humanize, d] }, params[:diet]),
                       { include_blank: "Tous" },
                       class: "filter-select#{' filter-select--active' if has_diet}",
                       data: { action: "change->recipe-filter#submit" }

          .filter-group
            = f.label :difficulty, "Difficulté", class: "filter-label"
            = f.select :difficulty,
                       options_for_select(Recipe.difficulties.keys.map { |d| [d.humanize, d] }, params[:difficulty]),
                       { include_blank: "Toutes" },
                       class: "filter-select#{' filter-select--active' if has_diff}",
                       data: { action: "change->recipe-filter#submit" }

          .filter-group
            = f.label :max_time, "Temps max", class: "filter-label"
            = f.select :max_time,
                       options_for_select([["15 min", 15], ["30 min", 30], ["45 min", 45], ["1h", 60], ["1h30", 90]], params[:max_time]),
                       { include_blank: "Illimité" },
                       class: "filter-select#{' filter-select--active' if has_time}",
                       data: { action: "change->recipe-filter#submit" }

          .filter-group.filter-checkbox{ class: has_seasonal ? "filter-checkbox--active" : nil }
            = f.check_box :seasonal,
                          { checked: has_seasonal,
                            data: { action: "change->recipe-filter#submit" } },
                          "true", nil
            = f.label :seasonal, "🌿 De saison", class: "filter-label-inline"

        -# ── Filtres actifs (badges supprimables) ──
        - if has_any_filter
          .active-filters-bar
            %span.active-filters-label Actifs :
            - if has_query
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "query" } }
                🔍 #{params[:query]}
                %span.badge-remove ×
            - if has_diet
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "diet" } }
                = params[:diet].humanize
                %span.badge-remove ×
            - if has_diff
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "difficulty" } }
                = params[:difficulty].humanize
                %span.badge-remove ×
            - if has_time
              - time_labels = { "15" => "≤ 15 min", "30" => "≤ 30 min", "45" => "≤ 45 min", "60" => "≤ 1h", "90" => "≤ 1h30" }
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "max_time" } }
                = time_labels[params[:max_time].to_s] || "≤ #{params[:max_time]} min"
                %span.badge-remove ×
            - if has_seasonal
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "seasonal" } }
                🌿 De saison
                %span.badge-remove ×
            - if has_favs
              %button.active-filter-badge{ type: "button",
                                           data: { action: "click->recipe-filter#clearFilter",
                                                   recipe_filter_field: "favorites" } }
                ♥ Mes favoris
                %span.badge-remove ×
            - if tags_count > 0
              - @tags&.select { |t| selected_tag_ids.include?(t.id.to_s) }.each do |tag|
                %button.active-filter-badge{ type: "button",
                                             data: { action: "click->recipe-filter#clearFilter",
                                                     recipe_filter_field: "tag_ids[]",
                                                     recipe_filter_value: tag.id } }
                  #{tag.name}
                  %span.badge-remove ×

        -# ── Tags par catégorie (cases à cocher verticales) ──
        - if @tags&.any?
          - tag_type_labels = { "rapidite" => "Rapidité", "regime_alimentaire" => "Régime alimentaire",
                                "occasion" => "Occasion", "methode_cuisson" => "Méthode de cuisson",
                                "saison" => "Saison", "autre" => "Autre" }
          - tags_by_type = @tags.group_by { |t| t.tag_type || "autre" }
          .filters-tags-section
            - tag_type_labels.each do |type, label|
              - group = tags_by_type[type]
              - next unless group&.any?
              .filters-tags-group
                %span.filters-tags-sublabel= label
                .filters-tags-list
                  - group.each do |tag|
                    - tag_active = selected_tag_ids.include?(tag.id.to_s)
                    .filter-tag-check
                      = check_box_tag "tag_ids[]", tag.id, tag_active,
                                      id: "tag-#{tag.id}",
                                      class: "filter-tag-input",
                                      data: { action: "change->recipe-filter#submit" }
                      = label_tag "tag-#{tag.id}", tag.name,
                                  class: "filter-tag-check-label#{ ' active' if tag_active}"

        -# Fin du formulaire de filtres

    -# ── Colonne droite : Résultats ──────────────────────
    .recipes-main
      -# ── Header (dans la colonne principale pour que la sidebar soit pleine hauteur) ──
      .recipes-header
        %h1
          = inline_svg("cook-book", css_class: "icon-title", color: "var(--color-primary)")
          Catalogue de recettes
        - if policy(Recipe).create?
          = link_to new_recipe_path, class: "btn btn-primary" do
            %span.btn-icon ✚
            Ajouter une recette

      -# ── Barre contextuelle menu brouillon ──
      - if current_user
        = render "recipes/draft_status_bar", draft: @draft

      -# Loader de chargement
      .recipes-loader.hidden{ data: { recipe_filter_target: "loader" } }
        .loader-spinner
        %span Recherche en cours...

      -# Liste des recettes (Turbo Frame pour rechargement partiel)
      .recipes-results{ data: { recipe_filter_target: "results" } }
        = turbo_frame_tag "recipes_list" do
          - if @recipes.any?
            .recipes-count
              %strong= @pagy.count
              = " recette#{'s' if @pagy.count > 1} trouvée#{'s' if @pagy.count > 1}"
            .recipes-grid
              - @recipes.each do |recipe|
                .recipe-card-wrapper
                  = link_to recipe_path(recipe), class: "recipe-card-link", data: { turbo_frame: "_top" } do
                    .recipe-card
                      .recipe-card-image-wrapper
                        - if recipe.photo.attached?
                          = image_tag cloudinary_photo_url(recipe.photo, width: 400, height: 250, crop: :fill),
                                      alt: recipe.name,
                                      class: "recipe-card-image"
                        - else
                          = image_tag "photo_par_defaut_recette.png", alt: recipe.name, class: "recipe-card-image"

                      .recipe-card-body
                        %h3.recipe-card-title= recipe.name

                        .recipe-card-meta
                          %span.meta-item
                            %span.meta-icon ⏱️
                            = format_total_time(recipe)
                          %span.meta-item
                            = diet_badge(recipe.diet)

                        - if recipe.tags.any?
                          .recipe-card-tags
                            - recipe.tags.first(3).each do |tag|
                              %span.badge.badge-beige= tag.name

                        .recipe-card-footer
                          .recipe-rating
                            %span.recipe-rating-stars= rating_stars(recipe.rating_avg)
                            %span.recipe-rating-count (#{recipe.reviews_count})

                  -# Coeur favori en overlay sur la carte
                  - if current_user
                    = render "recipes/favorite_button", recipe: recipe,
                                                        is_favorited: recipe.favorited_by?(current_user),
                                                        container_id: "favorite-btn-#{recipe.id}",
                                                        compact: true

                  -# Bouton ajout/retrait du menu brouillon en overlay
                  - if current_user && @draft
                    = render "recipes/draft_button", recipe: recipe,
                                                     in_draft: @draft_recipe_ids.include?(recipe.id),
                                                     container_id: "draft-btn-#{recipe.id}"

            .pagination-container
              = pagy_nav(@pagy) if @pagy.pages > 1

          - else
            .empty-state
              .empty-state-icon 🍳
              %h2 Aucune recette trouvée
              %p Essaye de modifier tes critères de recherche ou ajoute une nouvelle recette.
              - if policy(Recipe).create?
                = link_to "Ajouter une recette", new_recipe_path, class: "btn btn-primary"
