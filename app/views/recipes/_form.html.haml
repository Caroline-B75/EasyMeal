-# Formulaire partagé pour création/édition de recette
-# Design Slate Craft Premium — cohérent avec la fiche recette

.recipe-form-wrapper{ data: { controller: "slideout" } }
  = form_with model: recipe, class: "rf-form", data: { controller: "nested-form form-errors", turbo: false } do |f|

    -# Section : Informations générales
    .rf-section
      .rf-section-label INFORMATIONS GÉNÉRALES

      .form-row
        .form-group.form-group-large{ class: field_error_class(recipe, :name) }
          = f.label :name, "Nom de la recette *", class: "form-label"
          = f.text_field :name, class: "form-input", placeholder: "Ex: Pâtes carbonara", required: true
          = field_errors(recipe, :name)

        .form-group{ class: field_error_class(recipe, :default_servings) }
          = f.label :default_servings, "Personnes *", class: "form-label"
          = f.number_field :default_servings, class: "form-input", min: 1, value: recipe.default_servings || 4, required: true
          = field_errors(recipe, :default_servings)

    -# Section : Caractéristiques
    .rf-section
      .rf-section-label CARACTÉRISTIQUES

      .form-row
        .form-group{ class: field_error_class(recipe, :diet) }
          = f.label :diet, "Régime alimentaire *", class: "form-label"
          = f.select :diet, Recipe.diets.keys.map { |d| [d.humanize, d] }, { prompt: "Sélectionnez un régime" }, class: "form-select", required: true
          = field_errors(recipe, :diet)

        .form-group{ class: field_error_class(recipe, :difficulty) }
          = f.label :difficulty, "Difficulté", class: "form-label"
          = f.select :difficulty, Recipe.difficulties.keys.map { |d| [d.humanize, d] }, { include_blank: "Non renseignée" }, class: "form-select"
          = field_errors(recipe, :difficulty)

        .form-group{ class: field_error_class(recipe, :price) }
          = f.label :price, "Budget", class: "form-label"
          = f.select :price, Recipe.prices.keys.map { |p| [p.humanize, p] }, { include_blank: "Non renseigné" }, class: "form-select"
          = field_errors(recipe, :price)

      .form-row
        .form-group{ class: field_error_class(recipe, :prep_time_minutes) }
          = f.label :prep_time_minutes, "Préparation (min)", class: "form-label"
          = f.number_field :prep_time_minutes, class: "form-input", min: 0, placeholder: "Ex: 20"
          = field_errors(recipe, :prep_time_minutes)

        .form-group{ class: field_error_class(recipe, :cook_time_minutes) }
          = f.label :cook_time_minutes, "Cuisson (min)", class: "form-label"
          = f.number_field :cook_time_minutes, class: "form-input", min: 0, placeholder: "Ex: 30"
          = field_errors(recipe, :cook_time_minutes)

    -# Section : Tags
    .rf-section
      .rf-section-label TAGS

      .form-group
        - tag_category_labels = { "rapidite" => "Rapidité", "regime_alimentaire" => "Régime alimentaire",
                                   "occasion" => "Occasion", "methode_cuisson" => "Méthode de cuisson",
                                   "saison" => "Saison", "autre" => "Autre" }
        - %w[rapidite regime_alimentaire occasion methode_cuisson saison autre].each do |category|
          .rf-tags-group
            .rf-tags-category= tag_category_labels[category]
            .tags-grid
              - Tag.where(tag_type: category).alphabetical.each do |tag|
                %label.tag-checkbox
                  = f.check_box :tag_ids, { multiple: true, checked: recipe.tags.include?(tag) }, tag.id, nil
                  %span.tag-name= tag.name

    -# Section : Photo
    .rf-section
      .rf-section-label PHOTO

      .form-group{ data: { controller: "image-preview" } }
        - if recipe.persisted? && recipe.photo.attached?
          .current-photo
            = image_tag cloudinary_photo_url(recipe.photo, width: 200, height: 150), class: "photo-preview"
          %button.rf-btn-outline{ type: "button", data: { image_preview_target: "changeButton", action: "click->image-preview#showUploadField" } } Changer de photo

          .photo-upload-area{ data: { image_preview_target: "uploadArea" }, hidden: true }
            %label.rf-btn-photo{ for: "recipe_photo" } Ajouter une photo
            = f.file_field :photo, accept: "image/*", id: "recipe_photo", class: "photo-upload-input", data: { image_preview_target: "input", action: "change->image-preview#showFilename" }
            %small.rf-hint Format recommandé : JPEG ou PNG, 800×600 minimum
            %p.photo-upload-notice{ data: { image_preview_target: "notice" }, hidden: true }
        - else
          .rf-photo-upload
            %label.rf-btn-photo{ for: "recipe_photo" } Ajouter une photo
            = f.file_field :photo, accept: "image/*", id: "recipe_photo", class: "photo-upload-input", data: { image_preview_target: "input", action: "change->image-preview#showFilename" }
            %small.rf-hint Format recommandé : JPEG ou PNG, 800×600 minimum
            %p.photo-upload-notice{ data: { image_preview_target: "notice" }, hidden: true }

    -# Section : Ingrédients (nested fields)
    .rf-section
      .rf-section-label INGRÉDIENTS

      - if recipe.errors[:base].any?
        .field-errors
          - recipe.errors[:base].each do |message|
            %span.field-error= message

      .preparations-container{ data: { nested_form_target: "container" } }
        %template{ data: { nested_form_target: "template" } }
          = f.fields_for :preparations, Preparation.new, child_index: "NEW_RECORD" do |pf|
            = render "recipes/preparation_fields", f: pf

        = f.fields_for :preparations do |pf|
          = render "recipes/preparation_fields", f: pf

      .preparations-actions
        %button.rf-btn-add{ type: "button", data: { action: "click->nested-form#add" } }
          + Ajouter un ingrédient

        %button.rf-btn-create{ type: "button", data: { action: "click->slideout#open" } }
          + Créer un nouvel ingrédient

      #ingredient-created-notification

    -# Section : Instructions
    .rf-section
      .rf-section-label PRÉPARATION

      .form-group{ class: field_error_class(recipe, :instructions) }
        = f.label :instructions, "Étapes de préparation", class: "form-label"
        = f.text_area :instructions, class: "form-textarea", rows: 10, placeholder: "Faire bouillir l'eau...\nAjouter les pâtes...\n..."
        = field_errors(recipe, :instructions)

    -# Actions du formulaire
    .rf-actions
      = f.submit recipe.new_record? ? "Créer la recette" : "Mettre à jour", class: "btn btn-primary"
      = link_to "Annuler", recipes_path, class: "rf-cancel-link"

  -# Slideout pour créer un ingrédient à la volée
  .slideout-overlay{ data: { slideout_target: "overlay", action: "click->slideout#closeOnOverlay" } }
  .slideout-panel{ data: { slideout_target: "panel" } }
    .slideout-header
      %h3 Créer un nouvel ingrédient
      %button.slideout-close{ type: "button", data: { action: "click->slideout#close" } }
        ✕
    .slideout-content#quick-ingredient-form
      = render "ingredients/quick_form", ingredient: Ingredient.new