-# Partial pour afficher une carte d'avis
-# @param review [Review] L'avis à afficher
-# @param current_user [User] L'utilisateur connecté (optionnel)

.review-card{ id: "review_#{review.id}" }
  .review-header
    %span.review-author= review.user.username
    .review-rating-wrapper
      %span.review-rating= review.stars_display
      - if defined?(current_user) && current_user && review.user == current_user
        = form_with url: remove_review_recipe_path(review.recipe), method: :delete, data: { controller: "modal", turbo: true } do |f|
          %button.icon-btn-delete-small{ type: "button", data: { action: "click->modal#open" }, title: "Supprimer" }
            🗑️
          = render "shared/delete_confirmation_modal", resource_name: "avis"
  - if review.content.present?
    .review-content= review.content
