-# Formulaire pour créer/éditer un ingrédient avec SimpleForm
= simple_form_for ingredient, html: { class: "ingredient-form", data: { controller: "ingredient-form form-errors", turbo: false } } do |f|

  = f.error_notification message: "Des erreurs empêchent la sauvegarde :"

  .form-group
    = f.input :name, 
              label: "Nom de l'ingrédient *",
              placeholder: "Ex: Tomates",
              input_html: { class: "form-input" },
              label_html: { class: "form-label" },
              error_class: "has-error"

  .form-group
    = f.input :category, 
              label: "Rayon *",
              collection: Ingredient.categories.map { |k, _v| [Ingredient.human_attribute_name("category.#{k}"), k] },
              prompt: "Sélectionnez un rayon",
              input_html: { class: "form-select" },
              label_html: { class: "form-label" },
              hint_html: { class: "form-hint" },
              error_class: "has-error"

  .form-group
    = f.input :unit_group, 
              label: "Groupe d'unités *",
              collection: Ingredient.unit_groups.map { |k, _v| [Ingredient.human_attribute_name("unit_group.#{k}"), k] },
              prompt: "Sélectionnez un groupe",
              input_html: { class: "form-select", data: { ingredient_form_target: "unitGroup", action: "change->ingredient-form#updateBaseUnit" } },
              label_html: { class: "form-label" },
              hint_html: { class: "form-hint" },
              error_class: "has-error"

  .form-group
    = f.input :base_unit, 
              label: "Unité de base *",
              hint: "Déterminée automatiquement",
              placeholder: "Ex: g, ml, piece, cac",
              readonly: true,
              input_html: { class: "form-input", data: { ingredient_form_target: "baseUnit" } },
              label_html: { class: "form-label" },
              hint_html: { class: "form-hint" },
              error_class: "has-error"

  .form-group
    %label.form-label Alias (synonymes)
    %small.form-hint Noms alternatifs pour faciliter ta recherche
    = text_field_tag "ingredient[aliases]", 
                     ingredient.aliases.is_a?(Array) ? ingredient.aliases.join(', ') : '', 
                     class: "form-input", 
                     placeholder: "Ex: tomate, tomate fraîche (séparés par des virgules)"

  .form-group
    %label.form-label Mois de saison
    %small.form-hint Coche les mois où cet ingrédient est de saison
    = hidden_field_tag "ingredient[season_months][]", ""
    .months-grid
      - (1..12).each do |month|
        %label.month-checkbox
          = check_box_tag "ingredient[season_months][]", month, ingredient.season_months.include?(month), id: "ingredient_season_months_#{month}"
          %span= Date::ABBR_MONTHNAMES[month]

  .form-actions
    = f.submit ingredient.new_record? ? "Créer l'ingrédient" : "Mettre à jour", class: "btn btn-primary"
    = link_to "Annuler", ingredients_path, class: "btn btn-secondary"
